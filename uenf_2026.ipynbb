    {
      "cell_type": "markdown",
      "metadata": {
        "id": "8293d25e"
      },
      "source": [
        "### Média de Temperatura Mensal para a Região do Brasil (Parâmetros Atualizados)\n",
        "\n",
        "Agora, vamos calcular a temperatura média para cada mês disponível no conjunto de dados `ds_brazil_updated`."
      ]
    },
    {
      "cell_type": "code",
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/",
          "height": 1000
        },
        "id": "87c41b7e",
        "outputId": "27ba9a5b-7665-4257-cc04-2163be8dfe72"
      },
      "source": [
        "# Calcule a média de temperatura para cada mês\n",
        "# Primeiro, garantimos que a variável 't' esteja disponível no dataset\n",
        "if 't' in ds_brazil_updated.data_vars:\n",
        "    # Resample os dados por mês ('MS' para início do mês) e calcule a média\n",
        "    monthly_mean_temperature = ds_brazil_updated['t'].resample(valid_time='MS').mean(dim='valid_time')\n",
        "\n",
        "    print(\"Média de Temperatura Mensal (K) para a região do Brasil:\")\n",
        "    display(monthly_mean_temperature)\n",
        "\n",
        "    # Converter para Celsius\n",
        "    monthly_mean_temperature_celsius = monthly_mean_temperature - 273.15\n",
        "    print(\"\\nMédia de Temperatura Mensal (°C):\")\n",
        "    display(monthly_mean_temperature_celsius)\n",
        "else:\n",
        "    print(\"A variável 't' (temperatura) não foi encontrada no dataset ds_brazil_updated.\")\n"
      ],
      "execution_count": 26,
      "outputs": [
        {
          "output_type": "stream",
