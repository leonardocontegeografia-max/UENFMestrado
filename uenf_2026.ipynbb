      "cell_type": "code",
      "source": [
        "import pandas as pd\n",
        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "import cartopy.crs as ccrs\n",
        "import cartopy.feature as cfeature\n",
        "from scipy.interpolate import griddata"
      ],
      "metadata": {
        "id": "mxZcJfHB42iU"
      },
      "execution_count": 92,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "df = pd.read_csv(\"file.csv\")\n",
        "\n",
        "df[\"temp_c\"] = df[\"t\"] - 273.15\n",
        "\n",
        "df[\"latitude\"] = df[\"latitude\"].astype(float)\n",
        "df[\"longitude\"] = df[\"longitude\"].astype(float)"
      ],
      "metadata": {
        "id": "B6l8Xw0e4-bh"
      },
      "execution_count": 93,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "df_mean = df.groupby([\"latitude\", \"longitude\"], as_index=False)[\"temp_c\"].mean()"
      ],
      "metadata": {
        "id": "osB2HAki5A28"
      },
      "execution_count": 94,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "x = df_mean[\"longitude\"].values\n",
        "y = df_mean[\"latitude\"].values\n",
        "z = df_mean[\"temp_c\"].values"
      ],
      "metadata": {
        "id": "hmhBUqcK5Dyh"
      },
      "execution_count": 95,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "xi = np.linspace(-49.2, -48.7, 200)\n",
        "yi = np.linspace(-2.25, -1.75, 200)\n",
        "\n",
        "xi, yi = np.meshgrid(xi, yi)"
      ],
      "metadata": {
        "id": "37j_Ldvq5GPa"
      },
      "execution_count": 96,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "zi = griddata(\n",
        "    (x, y),\n",
        "    z,\n",
        "    (xi, yi),\n",
        "    method=\"linear\"\n",
        ")\n",
        "\n",
        "# evitar buracos\n",
        "zi = np.nan_to_num(zi, nan=np.nanmean(z))"
      ],
      "metadata": {
        "id": "fz1LPrpL5KTp"
      },
      "execution_count": 97,
      "outputs": []
    },
