    {
      "cell_type": "code",
      "source": [
        "import numpy as np\n",
        "from scipy.interpolate import griddata"
      ],
      "metadata": {
        "id": "diAgb-apwd3J"
      },
      "execution_count": 57,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "x = gdf_mean[\"longitude\"].values\n",
        "y = gdf_mean[\"latitude\"].values\n",
        "z = gdf_mean[\"temp_c\"].values"
      ],
      "metadata": {
        "id": "mNVoUEcCwhgL"
      },
      "execution_count": 58,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "xi = np.linspace(lon_min, lon_max, 200)\n",
        "yi = np.linspace(lat_min, lat_max, 200)\n",
        "\n",
        "xi, yi = np.meshgrid(xi, yi)"
      ],
      "metadata": {
        "id": "6WvkNj__wkNq"
      },
      "execution_count": 59,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "zi = griddata(\n",
        "    (x, y),\n",
        "    z,\n",
        "    (xi, yi),\n",
        "    method=\"cubic\"\n",
        ")"
      ],
      "metadata": {
        "id": "9hMcYTw3wnSa"
      },
      "execution_count": 60,
      "outputs": []
