      "cell_type": "code",
      "source": [
        "ax.set_title(\"Temperatura média ERA5 - Igarapé-Miri (2024)\")\n",
        "ax.set_axis_off()\n",
        "\n",
        "plt.show()"
      ],
      "metadata": {
        "id": "7yL1zyi6zLdy"
