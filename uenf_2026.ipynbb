      "source": [
        "# Re-executing the cell to display the head of the DataFrame\n",
        "temp_data_2d = ds['t'].isel(time=0, pressure_level=0)\n",
        "temp_df = temp_data_2d.to_dataframe()\n",
        "display(temp_df.head())"
      ],
